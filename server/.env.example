# 複製這個檔案為 .env，並填入你的 Anthropic API Key
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxx

# 使用的 Claude model（可依 Anthropic Console 上顯示的最新可用型號調整）
CLAUDE_MODEL=claude-sonnet-4-5-20250929

# 後端伺服器 port（部署平台通常會自動指定，可不填）
PORT=5174

# 正式部署時，填入前端的實際網址（限制誰能呼叫這個 API）。
# 本機開發不需要填，留空即可允許任何來源。
# 例如：CORS_ORIGIN=https://your-app.vercel.app
CORS_ORIGIN=

# Supabase 專案設定（Settings -> API 頁面可以找到）
# SUPABASE_SERVICE_ROLE_KEY 是有完整寫入權限的 key，絕對不能外流、不能出現在前端或 Git repo
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
